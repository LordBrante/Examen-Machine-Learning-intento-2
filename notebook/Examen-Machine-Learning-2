            "Features numéricas (6): ['age', 'balance', 'day', 'campaign', 'pdays', 'previous']\n",
            "Features categóricas (9): ['job', 'marital', 'education', 'default', 'housing', 'loan', 'contact', 'month', 'poutcome']\n",
            "\n",
            "Shape de X: (45211, 15)\n",
            "Distribución del target:\n",
            "{0: 39922, 1: 5289}\n"
          ]
        }
      ],
      "source": [
        "# Excluir leakage y target\n",
        "EXCLUIR = ['duration', 'y']\n",
        "\n",
        "feature_cols = [c for c in df.columns if c not in EXCLUIR]\n",
        "\n",
        "X = df[feature_cols].copy()\n",
        "y_target = df['y'].copy()\n",
        "\n",
        "# Separar por tipo\n",
        "num_cols_model = X.select_dtypes(include=np.number).columns.tolist()\n",
        "cat_cols_model = X.select_dtypes(include='object').columns.tolist()\n",
        "\n",
        "print(f'Features numéricas ({len(num_cols_model)}): {num_cols_model}')\n",
        "print(f'Features categóricas ({len(cat_cols_model)}): {cat_cols_model}')\n",
        "print(f'\\nShape de X: {X.shape}')\n",
        "print(f'Distribución del target:\\n{y_target.value_counts().to_dict()}')"
      ]
    },
