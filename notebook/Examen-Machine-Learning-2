            "Distribución en train:\n",
            "{0: '88.3%', 1: '11.7%'}\n",
            "\n",
            "Distribución en test:\n",
            "{0: '88.3%', 1: '11.7%'}\n"
          ]
        }
      ],
      "source": [
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y_target, test_size=0.2, random_state=42, stratify=y_target\n",
        ")\n",
        "\n",
        "print(f'Train: {X_train.shape[0]:,} filas | Test: {X_test.shape[0]:,} filas')\n",
        "print(f'\\nDistribución en train:')\n",
        "print(y_train.value_counts(normalize=True).map(lambda x: f'{x:.1%}').to_dict())\n",
        "print(f'\\nDistribución en test:')\n",
        "print(y_test.value_counts(normalize=True).map(lambda x: f'{x:.1%}').to_dict())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "SdajikYdmZUu"
      },
      "source": [
        "## 4.3 ColumnTransformer — Pipeline de preprocesamiento\n",
        "\n",
        "Se construye un `ColumnTransformer` que aplica:\n",
        "- **Variables numéricas:** Imputación con mediana + `StandardScaler`\n",
        "- **Variables categóricas:** Imputación con moda + `OrdinalEncoder`\n",
        "\n",
        "Este preprocesador se encapsula dentro de un `Pipeline` junto al clasificador, garantizando que no haya ningún tipo de leakage de información del set de test durante el ajuste."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 81,
      "metadata": {
        "id": "VI8Ynd--mZUu",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "a9e2a497-20de-4422-b4fc-4eb77ba0a208"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "ColumnTransformer configurado:\n",
            "  Numéricas → mediana + StandardScaler: ['age', 'balance', 'day', 'campaign', 'pdays', 'previous']\n",
            "  Categóricas → moda + OrdinalEncoder:  ['job', 'marital', 'education', 'default', 'housing', 'loan', 'contact', 'month', 'poutcome']\n"
          ]
        }
      ],
      "source": [
        "# Preprocesador numérico: mediana + escalado estándar\n",
        "numeric_transformer = Pipeline(steps=[\n",
        "    ('imputer', SimpleImputer(strategy='median')),\n",
        "    ('scaler',  StandardScaler())\n",
        "])\n",
        "\n",
        "# Preprocesador categórico: moda + codificación ordinal\n",
        "categorical_transformer = Pipeline(steps=[\n",
        "    ('imputer', SimpleImputer(strategy='most_frequent')),\n",
        "    ('encoder', OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1))\n",
        "])\n",
        "\n",
        "# ColumnTransformer que une ambos preprocesadores\n",
        "preprocessor = ColumnTransformer(\n",
        "    transformers=[\n",
        "        ('num', numeric_transformer,    num_cols_model),\n",
        "        ('cat', categorical_transformer, cat_cols_model)\n",
        "    ],\n",
        "    remainder='drop'\n",
        ")\n",
        "\n",
        "print('ColumnTransformer configurado:')\n",
        "print(f'  Numéricas → mediana + StandardScaler: {num_cols_model}')\n",
        "print(f'  Categóricas → moda + OrdinalEncoder:  {cat_cols_model}')"
      ]
    },
